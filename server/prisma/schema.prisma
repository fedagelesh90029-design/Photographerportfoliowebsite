generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Photo {
  id          Int      @id @default(autoincrement())
  url         String
  category    String
  description String?
  createdAt   DateTime @default(now())
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Info {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Review {
  id        Int      @id @default(autoincrement())
  name      String
  content   String
  rating    Int
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Subscriber {
  id         Int      @id @default(autoincrement())
  telegramId String?  @unique
  username   String?
  createdAt  DateTime @default(now())
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}
